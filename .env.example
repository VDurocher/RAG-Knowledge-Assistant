# ─── Required ────────────────────────────────────────────────────────────────
# Your OpenAI API key — required for answer generation
OPENAI_API_KEY=sk-...

# ─── Embeddings ──────────────────────────────────────────────────────────────
# "local"  → HuggingFace sentence-transformers (free, runs on CPU)
# "openai" → OpenAI text-embedding-3-small (better accuracy, ~$0.02 per 1M tokens)
EMBEDDER_TYPE=local

# HuggingFace model to use when EMBEDDER_TYPE=local
LOCAL_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ─── Generation ──────────────────────────────────────────────────────────────
# OpenAI chat model for answer generation
# Recommended: gpt-4o-mini (fast + cheap) or gpt-4o (highest accuracy)
OPENAI_CHAT_MODEL=gpt-4o-mini

# ─── Retrieval ───────────────────────────────────────────────────────────────
# Number of document passages retrieved per query (higher = more context, slower)
RETRIEVAL_K=4

# ─── Chunking ────────────────────────────────────────────────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
